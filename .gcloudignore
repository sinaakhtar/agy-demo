# Explicitly allow antigravity-oauth-token in Cloud Build tarball
!antigravity-oauth-token

# Exclude large binaries, Terraform state, and git metadata
.git/
.gitignore
bin/
*.zip
*.tar.gz
.terraform/
terraform/.terraform/
terraform/*.tfstate*
node_modules/
backend/node_modules/
*.log
scratch/
.idea/
.vscode/
